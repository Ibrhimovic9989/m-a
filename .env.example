# --------------------------------------------------------------------
# Muneer & Associates — environment variables
# --------------------------------------------------------------------
# Copy to `.env.local` for local development, or add each value as a
# Project Environment Variable in Vercel for production.
# --------------------------------------------------------------------

# Cal.com booking link shown in the appointment iframe.
# Format: "<username>/<event-type-slug>"
# Example: ca-muneer-ahmed/30min
NEXT_PUBLIC_CAL_LINK=ca-muneer-ahmed/30min

# Cal.com webhook signing secret. Must match the value entered in
# Cal.com → Settings → Developer → Webhooks → (edit) → Secret.
# Used to verify the X-Cal-Signature-256 header on every webhook hit.
CAL_WEBHOOK_SECRET=

# Cal.com personal access token (server-only, never exposed to the
# browser). Used for outbound API calls back to Cal.com — fetching
# bookings, programmatic event-type creation, etc. Generate at
# Cal.com → Settings → Developer → API keys.
CAL_API_KEY=
